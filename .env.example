# StrikeAgent-CLI 环境变量示例（复制为 .env 后填写；.env 已被 .gitignore 忽略）
# 兼容 Claude Code 的变量名。

# ---- DeepSeek（默认，推荐）----
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-在此填入你的DeepSeekKey
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# 思考强度：high | max
CLAUDE_CODE_EFFORT_LEVEL=max

# 也可用 DEEPSEEK_API_KEY 代替 ANTHROPIC_AUTH_TOKEN
# DEEPSEEK_API_KEY=sk-在此填入你的DeepSeekKey

# ---- Ollama（本地，可选）----
# STRIKE_USE_OLLAMA=1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:7b

# ---- 飞书远程操控（可选）----
# FEISHU_APP_ID=cli_你的AppID
# FEISHU_APP_SECRET=你的AppSecret
